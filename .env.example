# ─────────────────────────────────────
# LINE Messaging API
# ─────────────────────────────────────
# LINE Developers Console → プロバイダー → チャネル → Messaging API設定 で取得

# チャネルシークレット（Basic settings → Channel secret）
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# チャネルアクセストークン（Messaging API設定 → Channel access token → Issue）
LINE_CHANNEL_ACCESS_TOKEN=eyJ...（長いトークン）

# ─────────────────────────────────────
# 暗号化キー
# ─────────────────────────────────────
# 以下のコマンドで生成:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
