# ──────────────────────────────────────────────
# ローカル実行用 環境変数サンプル
# このファイルを .env にコピーして値を入力してください
# ※ .env は絶対に Git にコミットしないこと！
# ──────────────────────────────────────────────

# 工学院大学 Moodle の URL（末尾スラッシュなし）
MOODLE_URL=https://lms.kogakuin.ac.jp

# Moodle ログイン情報（学籍番号とパスワード）
MOODLE_USERNAME=your_student_id
MOODLE_PASSWORD=your_password

# LINE Messaging API チャンネルアクセストークン
# LINE Developers Console → チャンネル → Messaging API → チャンネルアクセストークン
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# 通知先 LINE ユーザーID（自分の User ID）
# LINE Developers Console → チャンネル → Messaging API → あなたのユーザーID
LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 何日前に通知するか（カンマ区切りで複数指定可）
# 例: "1" → 前日のみ / "1,3,7" → 前日・3日前・7日前
NOTIFY_DAYS_BEFORE=1
